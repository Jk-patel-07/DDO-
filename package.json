{
  "name": "ddo",
  "private": true,
  "version": "0.0.0",
  "ddoVersion": "DOI-1",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 3000 --strictPort",
    "dev:full": "node tools/dev-with-backend.mjs",
    "backend": "node server.mjs",
    "wifi-backend": "node server.mjs",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "tauri": "tauri",
    "electron:dev": "concurrently \"npm run dev\" \"npm run backend\" \"wait-on http://127.0.0.1:3000 http://127.0.0.1:5000 && electron electron/main.cjs\"",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^1.16.0",
    "mongoose": "^9.6.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "react-syntax-highlighter": "^16.1.1",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.ddo.app",
    "productName": "ddo",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "src-tauri/icons/icon.ico"
    ],
    "win": {
      "target": "nsis",
      "icon": "src-tauri/icons/icon.ico"
    }
  }
}
